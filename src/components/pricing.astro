---
import { Tick } from "@/components/ui/icons";
import Link from "@/components/ui/link.astro";

const { plan } = Astro.props;
---

<div>
  <div
    class={`flex flex-col w-full order-first lg:order-none py-6 px-7 rounded-2xl border transition-all duration-300 ${
      plan.popular
        ? "border-black shadow-xl scale-[1.02] bg-black text-white"
        : "border-[#D8DEE9] border-opacity-60 bg-white"
    }`}>

    {
      plan.popular && (
        <div class="mb-5">
          <span class="bg-white text-black text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wide">
            Most Popular
          </span>
        </div>
      )
    }

    <div class="text-center">
      <h4
        class={`text-lg font-medium ${
          plan.popular ? "text-slate-300" : "text-gray-500"
        }`}>
        {plan.name}
      </h4>

      <p
        class={`mt-4 text-5xl font-bold tracking-tight ${
          plan.popular ? "text-white" : "text-black"
        }`}>
        {
          plan.price && typeof plan.price === "object"
            ? plan.price.monthly
            : plan.price
        }
      </p>

      {
        plan.subtitle && (
          <p
            class={`mt-3 text-sm ${
              plan.popular ? "text-slate-400" : "text-slate-500"
            }`}>
            {plan.subtitle}
          </p>
        )
      }
    </div>

    <ul class="grid mt-10 text-left gap-y-4">
      {
        plan.features.map((item) => (
          <li
            class={`flex items-start gap-3 ${
              plan.popular ? "text-slate-100" : "text-gray-800"
            }`}>
            <Tick class="w-6 h-6 shrink-0" />
            <span>{item}</span>
          </li>
        ))
      }
    </ul>

    <div class="flex mt-10">
      <Link
        href={plan.button.link || "#"}
        block
        style={plan.popular ? "inverted" : "primary"}>
        {plan.button.text || "Book a Walkthrough"}
      </Link>
    </div>

    {
      plan.note && (
        <p
          class={`mt-5 text-xs text-center ${
            plan.popular ? "text-slate-500" : "text-slate-400"
          }`}>
            {plan.note}
          </p>
        )
      }
    }
  </div>
</div>
