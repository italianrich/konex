---
import Link from "./ui/link.astro";
---

<div
  class="bg-black p-8 md:px-20 md:py-20 mt-20 mx-auto max-w-5xl rounded-lg flex flex-col items-center text-center">

  <p class="uppercase tracking-[0.2em] text-slate-500 text-sm">
    Early Access for Estate Agencies
  </p>

  <h2 class="text-white text-4xl md:text-6xl tracking-tight mt-3 max-w-4xl">
    Never Miss Another Property Lead
  </h2>

  <p class="text-slate-400 mt-6 text-lg md:text-xl max-w-2xl">
    Konex Concierge helps agencies respond instantly, qualify buyers,
    capture seller valuation requests, and engage clients 24/7 —
    in multiple languages.
  </p>

  <div class="flex flex-col sm:flex-row gap-4 mt-8">
    <Link
      href="https://konex.click/demo"
      style="inverted">
      Try the Live Demo
    </Link>

    <Link
      href="https://konex.click/contact"
      style="outline">
      Book a 10-Minute Walkthrough
    </Link>
  </div>

  <p class="text-slate-500 mt-6 text-sm">
    Designed for modern estate agencies in France, Italy, Spain, the UK and the USA.
  </p>
</div>
