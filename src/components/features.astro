---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "Capture Seller Valuation Leads",
    description:
      "Turn website visitors into potential sellers with intelligent valuation flows that collect contact details and property information automatically.",
    icon: "bx:bxs-home",
  },
  {
    title: "Qualify Buyers Automatically",
    description:
      "Your AI concierge can answer property questions, understand buyer criteria, and guide visitors toward suitable listings instantly.",
    icon: "bx:bxs-conversation",
  },
  {
    title: "Available 24/7",
    description:
      "Never miss another enquiry outside office hours. The concierge responds instantly, even during evenings, weekends, and holidays.",
    icon: "bx:bxs-time-five",
  },
  {
    title: "Easy Website Integration",
    description:
      "Add the AI concierge to your existing agency website in minutes. Compatible with modern websites and property platforms.",
    icon: "bx:bxs-bot",
  },
  {
    title: "Multilingual Concierge",
    description:
      "Serve international buyers and sellers in English, French, Italian, Spanish, and more — automatically detected and translated.",
    icon: "bx:bxs-flag-alt",
  },
  {
    title: "Lead Tracking & Insights",
    description:
      "Track conversations, valuation requests, and client interactions with clear reporting that proves ROI to your agency.",
    icon: "bx:bxs-bar-chart-alt-2",
  },
];
---

<div class="mt-16 md:mt-0">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    A 24/7 AI Concierge for Modern Estate Agencies
  </h2>

  <p class="text-lg mt-4 text-slate-600 max-w-3xl">
    Konex Concierge helps estate agencies respond faster, qualify leads
    automatically, and capture more seller valuation requests — without hiring
    additional staff.
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16">
  {
    features.map((item) => (
      <div class="flex gap-4 items-start">
        <div class="mt-1 bg-black rounded-full p-2 w-8 h-8 shrink-0">
          <Icon class="text-white" name={item.icon} />
        </div>

        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>

          <p class="text-slate-500 mt-2 leading-relaxed">
            {item.description}
          </p>
        </div>
      </div>
    ))
  }
</div>
