---
import { Picture } from "astro:assets";
import heroImage from "@/assets/Konex-Hero.jpg";
import Link from "@/components/ui/link.astro";
import { Icon } from "astro-icon/components";
---

<main
  class="grid lg:grid-cols-2 place-items-center pt-16 pb-8 md:pt-12 md:pb-24">
  <div class="py-6 md:order-1 hidden md:block">
    <Picture
      src={heroImage}
      alt="AI concierge helping an estate agency capture property leads"
      widths={[200, 400, 600]}
      sizes="(max-width: 800px) 100vw, 620px"
      loading="eager"
      format="avif"
    />
  </div>

  <div>
    <p class="text-sm font-semibold tracking-widest uppercase text-slate-500">
      AI Concierge for Estate Agencies
    </p>

    <h1
      class="mt-3 text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter">
      Never Miss Another Property Lead
    </h1>

    <p class="text-lg mt-4 text-slate-600 max-w-xl">
      Give your agency a 24/7 AI concierge that answers buyer questions,
      qualifies sellers, books viewings, and captures valuation requests
      automatically — in English, French, Italian and Spanish.
    </p>

    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <Link
        href="https://n8n.konex.click"
        target="_blank"
        class="flex gap-1 items-center justify-center"
        rel="noopener">
        <Icon class="text-white w-5 h-5" name="carbon:demo" />
        Try the Live Demo
      </Link>

      <Link
        size="lg"
        style="outline"
        rel="noopener"
        href="https://konex.click/contact"
        class="flex gap-1 items-center justify-center"
        target="_blank">
        <Icon class="text-black w-4 h-4" name="bx:bxs-envelope" />
        Book a 10-Minute Walkthrough
      </Link>
    </div>

    <p class="mt-4 text-sm text-slate-500">
      Built for property agencies that want faster response times, better
      qualification, and more seller valuation leads.
    </p>
  </div>
</main>
